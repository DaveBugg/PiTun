# PiTun configuration

# Backend
SECRET_KEY=changeme-use-openssl-rand-hex-32
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./data/pitun.db

# xray
XRAY_BINARY=/usr/local/bin/xray
XRAY_CONFIG_PATH=/tmp/pitun/config.json
XRAY_GEOIP_PATH=/usr/local/share/xray/geoip.dat
XRAY_GEOSITE_PATH=/usr/local/share/xray/geosite.dat
XRAY_LOG_LEVEL=warning

# Network
TPROXY_PORT_TCP=7893
TPROXY_PORT_UDP=7894
DNS_PORT=5353
INTERFACE=eth0
LAN_CIDR=192.168.1.0/24
GATEWAY_IP=192.168.1.100

# GeoData defaults
GEOIP_URL=https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geoip.dat
GEOSITE_URL=https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geosite.dat

# Frontend (served by nginx)
VITE_API_BASE_URL=http://192.168.1.100/api
VITE_WS_BASE_URL=ws://192.168.1.100/api

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://192.168.1.100

# NaiveProxy sidecars
# Backend talks to Docker API via docker-socket-proxy (loopback only).
# Set automatically by docker-compose.yml; override only for debugging.
# DOCKER_HOST=tcp://127.0.0.1:2375
#
# Port range reserved for naive sidecar SOCKS5 listeners on 127.0.0.1.
# Each enabled naive node picks a free port from this range.
NAIVE_PORT_RANGE_START=20800
NAIVE_PORT_RANGE_END=20899
# Path on host where naive configs are generated
# (mounted into backend at /etc/pitun/naive)
NAIVE_CONFIG_DIR=/etc/pitun/naive
# Docker image tag for naive sidecars
NAIVE_IMAGE=pitun-naive:latest
